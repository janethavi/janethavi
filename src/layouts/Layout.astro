      <nav class="mx-auto flex h-20 max-w-6xl items-center justify-between px-6">
        <a href="/" class="flex items-center gap-2">
          <span class="text-xl font-bold tracking-tight text-gray-900">Janeth Fernando</span>
        </a>
        <!-- Desktop -->
        <ul class="hidden items-center gap-8 md:flex">
          {
            nav.map((n) => {
              const isActive =
                n.href === '/' ? currentPath === '/' : currentPath.startsWith(n.href);
              return (
                <li>
                  <a
                    href={n.href}
                    class={`text-base transition-colors hover:text-gray-900 ${isActive ? 'border-b-2 border-gray-900 pb-0.5 font-semibold text-gray-900' : 'font-medium text-gray-600'}`}
                  >
                    {n.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
        <!-- Mobile hamburger -->
        <button
          id="menu-btn"
          class="text-gray-500 hover:text-gray-900 md:hidden"
          aria-label="Toggle menu"
        >
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </nav>
      <!-- Mobile menu -->
