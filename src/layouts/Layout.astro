                  class={`block text-sm font-medium transition-colors hover:text-gray-900 ${(n.href === '/' ? currentPath === '/' : currentPath.startsWith(n.href)) ? 'font-semibold text-gray-900' : 'text-gray-600'}`}
                >
                  {n.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </header>

