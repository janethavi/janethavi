---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
}
const {
  title,
  description = 'Janeth Fernando — Associate Lead SRE at WSO2, content creator, and adventure seeker from Sri Lanka.',
  image = '/images/about/profile-hero.jpg',
  type = 'website',
} = Astro.props;
const siteUrl = 'https://janethfernando.me';
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
const nav = [
  { label: 'Home', href: '/' },
  { label: 'About Me', href: '/about' },
  { label: 'Gallery', href: '/gallery' },
  { label: 'Writings', href: '/writings' },
  { label: 'Life Updates', href: '/life-updates' },
  { label: 'Experiences', href: '/experiences' },
];
const currentPath = Astro.url.pathname;
// Footer Instagram grid: 6 latest posts, statically hosted (no widget, no branding).
// To refresh, save new thumbnails to /public/images/instagram and update the codes.
const instagramPosts = [
  'DD9aQIJhHrI',
  'DZCHQQFuNcI',
  'DY90iu6uo8l',
  'DFox0QlhTu6',
  'C9e9rfJBX-h',
  'C3e80EMhSXA',
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Janeth Fernando" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@janethavishka" />
    <meta name="twitter:creator" content="@janethavishka" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Additional SEO -->
    <meta name="author" content="Janeth Fernando" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#ffffff" />

    <!-- JSON-LD WebSite schema (matches live site) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org/',
        '@type': 'WebSite',
        name: 'Janeth Fernando',
        url: siteUrl,
        description:
          "Janeth Fernando is building a better future through technology, fueled by ambition and a relentless drive in the cloud. You'll find a diverse range of content, including detailed blogs, stunning photography, and a peek into Janeth's life and experiences.",
        image: `${siteUrl}/images/ai-logo-AE04XPKl85iDyrDk.svg`,
        inLanguage: 'en',
        keywords: ['Janeth Fernando', 'Website', 'Janeth Avishka'],
      })}
    />

    <!-- JSON-LD Person schema -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: 'Janeth Fernando',
        url: siteUrl,
        image: ogImage,
        jobTitle: 'Associate Lead Site Reliability Engineer',
        worksFor: { '@type': 'Organization', name: 'WSO2' },
        sameAs: [
          'https://www.linkedin.com/in/janethfernando/',
          'https://x.com/janethavishka',
          'https://www.instagram.com/_jan.eth_/',
          'https://www.youtube.com/@DaysofJaneth',
          'https://medium.com/@janethavishka',
          'https://github.com/janethavi',
          'https://www.facebook.com/janethavishka/',
          'https://www.threads.net/@_jan.eth_',
          'https://www.tiktok.com/@daysofjaneth',
        ],
        description: description,
        nationality: 'Sri Lankan',
      })}
    />

    <link
      rel="icon"
      type="image/png"
      href="/images/cropped-bitmoji-20190612081223-1-YD04BnzpqvueRqWY.png"
    />
    <link
      rel="apple-touch-icon"
      href="/images/cropped-bitmoji-20190612081223-1-YD04BnzpqvueRqWY.png"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap"
